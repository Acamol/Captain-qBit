<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Qbit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="popupMenuStyle">@style/PopupMenu</item>

        <item name="colorPrimary">@color/theme_primary</item>
        <item name="colorOnPrimary">@color/theme_on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_on_primary_container</item>
        <item name="colorSecondary">@color/theme_secondary</item>
        <item name="colorOnSecondary">@color/theme_on_secondary</item>
        <item name="colorSecondaryContainer">@color/theme_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/theme_on_secondary_container</item>
        <item name="colorError">@color/theme_error</item>
        <item name="colorErrorContainer">@color/theme_error_container</item>
        <item name="colorOnError">@color/theme_on_error</item>
        <item name="colorOnErrorContainer">@color/theme_on_error_container</item>
        <item name="android:colorBackground">@color/theme_background</item>
        <item name="colorOnBackground">@color/theme_on_background</item>
        <item name="colorSurface">@color/theme_surface</item>
        <item name="colorOnSurface">@color/theme_on_surface</item>
        <item name="colorSurfaceVariant">@color/theme_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/theme_on_surface_variant</item>
        <item name="colorOutline">@color/theme_outline</item>
        <item name="colorOnSurfaceInverse">@color/theme_inverse_on_surface</item>
        <item name="colorSurfaceInverse">@color/theme_inverse_surface</item>
        <item name="colorPrimaryInverse">@color/theme_inverse_primary</item>

        <!-- Material 3 type scale, all on Space Grotesk for consistent typography. -->
        <item name="textAppearanceTitleLarge">@style/TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/BodyMedium</item>
        <item name="textAppearanceBodyMedium">@style/BodyRegular</item>
        <item name="textAppearanceLabelLarge">@style/LabelLarge</item>
    </style>

    <style name="Theme.Qbit" parent="Base.Theme.Qbit" />

    <!-- Full-screen dialog used by the tabbed Add-torrent screen. -->
    <style name="FullScreenDialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
