<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BodyMedium" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="BodyRegular" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/space_grotesk</item>
    </style>

    <style name="LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/space_grotesk</item>
    </style>

    <style name="TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="fontFamily">@font/space_grotesk</item>
    </style>

    <style name="TitleMediumBold" parent="TitleMedium">
        <item name="android:textSize">17sp</item>
        <item name="fontWeight">500</item>
    </style>

    <style name="TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/space_grotesk</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">.05</item>
    </style>

    <style name="PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">?attr/colorSurfaceContainerHigh</item>
    </style>
</resources>
